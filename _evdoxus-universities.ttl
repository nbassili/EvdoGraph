@prefix       evdx: <https://w3id.org/evdoxus#> .
@prefix     schema: <https://schema.org/> .
@prefix        bow: <https://diuf.unifr.ch/xi/bowlogna/> .
@prefix   wikidata: <http://www.wikidata.org/entity/> .
@prefix      vCard: <http://www.w3.org/2006/vcard/ns#> .
@prefix        owl: <http://www.w3.org/2002/07/owl#> .
@prefix        xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix       rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix        rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix       vivo: <http://vivoweb.org/ontology/core#> .
@prefix       spin: <http://spinrdf.org/spin#> .
@prefix      aiiso: <http://purl.org/vocab/aiiso/schema#> .
@prefix       bibo: <http://purl.org/ontology/bibo/> .
@prefix      teach: <http://linkedscience.org/teach/ns#> .
@prefix dbpedia-el: <http://el.dbpedia.org/resource/> .
@prefix        dbr: <http://dbpedia.org/resource/> .
@prefix        dbo: <http://dbpedia.org/ontology/> .

# Named toplevel resources (87)

<https://w3id.org/evdoxus>
	a owl:Ontology ;
	spin:imports <http://topbraid.org/spin/owlrl-all> ;
	owl:versionInfo "Created with TopBraid Composer" .

evdx:AcademicEntity
	a owl:Class ;
	rdfs:label "Academic Entity" ;
	rdfs:subClassOf evdx:EvdoxusEntity .

evdx:Book
	a owl:Class ;
	rdfs:label "Book" ;
	rdfs:subClassOf teach:Material ,
			evdx:LearningEntity ;
	owl:equivalentClass dbo:Book ,
			    bibo:Book ,
			    wikidata:Q571 ,
			    schema:Book .

evdx:Course
	a owl:Class ;
	rdfs:label "Course" ;
	rdfs:subClassOf evdx:LearningEntity ;
	owl:equivalentClass teach:Course ,
			    aiiso:Course ,
			    vivo:Course ,
			    wikidata:Q600134 ,
			    bow:Module ,
			    schema:Course .

evdx:Department
	a owl:Class ;
	rdfs:label "Department" ;
	rdfs:subClassOf schema:School ,
			evdx:AcademicEntity ;
	owl:equivalentClass aiiso:Department ,
			    vivo:AcademicDepartment ,
			    wikidata:Q2467461 ,
			    bow:Department .

evdx:EvdoxusEntity
	a owl:Class ;
	rdfs:subClassOf owl:Thing .

evdx:ID
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned with external ontologies" ,
		     "The ID of the resource in the Evdoxus database" ;
	rdfs:domain evdx:EvdoxusEntity ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:LearningEntity
	a owl:Class ;
	rdfs:label "Learning Entity" ;
	rdfs:subClassOf evdx:EvdoxusEntity .

evdx:University
	a owl:Class ;
	rdfs:label "University" ;
	rdfs:subClassOf aiiso:Institution ,
			schema:CollegeOrUniversity ,
			evdx:AcademicEntity ;
	owl:equivalentClass dbo:University ,
			    vivo:University ,
			    wikidata:Q3918 .

evdx:authors
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "authors" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:backCover
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "backCover" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:belongsToUniversity
	a owl:ObjectProperty ;
	rdfs:comment "Department belongs to University" ,
		     "Needs to be aligned" ;
	rdfs:domain evdx:Department ;
	rdfs:range evdx:University ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf evdx:hasDepartment .

evdx:bookSize
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "bookSize" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:bookType
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "bookType" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:contents
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "contents" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:coverType
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "coverType" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:distributor
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "distributor" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:edition
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "edition" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:excerpt
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "excerpt" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:frontCover
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "frontCover" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:hasBook
	a owl:ObjectProperty ;
	rdfs:comment "Course has Book" ;
	rdfs:domain evdx:Course ;
	rdfs:label "has book" ;
	rdfs:range evdx:Book ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf wikidata:P366 ,
		      evdx:proposedForCourse .

evdx:hasCode
	a owl:DatatypeProperty ;
	rdfs:comment "Book or Course has Code" ,
		     "Needs to be aligned" ;
	rdfs:domain evdx:LearningEntity ;
	rdfs:label "has code" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:hasCourse
	a owl:ObjectProperty ;
	rdfs:comment "Department has Course" ;
	rdfs:domain evdx:Department ;
	rdfs:label "has course" ;
	rdfs:range evdx:Course ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf wikidata:P137 ,
		      schema:provider ,
		      evdx:isGivenByDepartment .

evdx:hasDepartment
	a owl:ObjectProperty ;
	rdfs:comment "Needs to be aligned" ,
		     "University has Department" ;
	rdfs:domain evdx:University ;
	rdfs:label "has department" ;
	rdfs:range evdx:Department ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf evdx:belongsToUniversity .

evdx:hasSchool
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Department ;
	rdfs:label "School Name" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:hasURL
	a owl:DatatypeProperty ;
	rdfs:comment "Book or Course has URL" ;
	rdfs:domain evdx:LearningEntity ;
	rdfs:label "has URL" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty ;
	owl:equivalentProperty vCard:hasURL ,
			       schema:url .

evdx:isGivenByDepartment
	a owl:ObjectProperty ;
	rdfs:comment "Course is given by Department" ,
		     "Needs to be aligned" ;
	rdfs:domain evdx:Course ;
	rdfs:range evdx:Department ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf evdx:hasCourse .

evdx:isbn
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "isbn" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:keyword
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "keyword" ;
	rdfs:range rdf:List ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:name
	a owl:DatatypeProperty ;
	rdfs:comment "University or Department name" ;
	rdfs:domain evdx:AcademicEntity ;
	rdfs:label "name" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty ;
	owl:equivalentProperty vCard:hasOrganizationName .

evdx:pages
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "pages" ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:professors
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned with external ontologies" ,
		     "Professors that teach the course" ;
	rdfs:domain evdx:Course ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:proposedForCourse
	a owl:ObjectProperty ;
	rdfs:comment "Book proposed for Course" ,
		     "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:range evdx:Course ;
	rdfs:subPropertyOf owl:topObjectProperty ;
	owl:inverseOf evdx:hasBook .

evdx:publicationYear
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "publicationYear" ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:publisher
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "publisher" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:publisherID
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "publisherID" ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:publisherWebPage
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aligned" ;
	rdfs:domain evdx:Book ;
	rdfs:label "publisherWebPage" ;
	rdfs:range xsd:anyURI ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:secretaryID
	a owl:DatatypeProperty ;
	rdfs:comment "Needs to be aglined" ,
		     "The ID of the secreariat of the Department. This is the ID that is used to link Departments to courses in the Evdoxus database." ;
	rdfs:domain evdx:Department ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:semester
	a owl:DatatypeProperty ;
	rdfs:comment "Course semester" ,
		     "Needs to be aligned" ;
	rdfs:domain evdx:Course ;
	rdfs:label "semester" ;
	rdfs:range xsd:integer ;
	rdfs:subPropertyOf owl:topDataProperty .

evdx:title
	a owl:DatatypeProperty ;
	rdfs:comment "Book or Course title" ;
	rdfs:domain evdx:LearningEntity ;
	rdfs:label "title" ;
	rdfs:range xsd:string ;
	rdfs:subPropertyOf owl:topDataProperty ;
	owl:equivalentProperty vCard:title .

